{{!< default}}

{{#post}}
<article class="oott-post oott-page">

  {{#if @page.show_title_and_feature_image}}
    <header class="post-hero">
      <h1 class="post-title">{{title}}</h1>
      {{#if custom_excerpt}}
        <p class="post-deck">{{custom_excerpt}}</p>
      {{/if}}
    </header>

    {{#if feature_image}}
      <figure class="post-feature-image">
        <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
      </figure>
    {{/if}}
  {{/if}}

  <div class="post-body gh-content">
    {{content}}
  </div>

</article>
{{/post}}
