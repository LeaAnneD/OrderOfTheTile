{{!< default}}

{{#post}}
<article class="oott-post">

  <header class="post-hero">
    <img class="post-seal" src="{{asset "images/seal.png"}}" alt="seal" />
    <p class="post-eyebrow">{{date published_at format="MMMM D, YYYY"}}{{#if primary_tag}} &middot; {{primary_tag.name}}{{/if}}</p>
    <h1 class="post-title">{{title}}</h1>
    {{#if custom_excerpt}}
      <p class="post-deck">{{custom_excerpt}}</p>
    {{/if}}
  </header>

  {{#if feature_image}}
    <figure class="post-feature-image">
      <img src="{{img_url feature_image size="xl"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
      {{#if feature_image_caption}}<figcaption>{{{feature_image_caption}}}</figcaption>{{/if}}
    </figure>
  {{/if}}

  <div class="post-body gh-content">
    {{content}}
  </div>

  <footer class="post-foot">
    <div class="post-foot-rule"></div>
    <p class="post-foot-sign">— Prim</p>

    {{#unless @member}}
      <div class="post-foot-cta">
        <h3>Subscribe to The Order of the Tile</h3>
        <p>Letters land weekly. Prim doesn&rsquo;t soften, repeat, or apologize.</p>
        <a href="#/portal/signup" data-portal="signup" class="btn-primary">Join the Table</a>
      </div>
    {{/unless}}
  </footer>

</article>

{{#if posts}}
  <section class="post-related">
    <h3 class="related-heading">More from the archive</h3>
    <div class="letters-grid">
      {{#foreach posts}}
        <article class="letter-card">
          <div class="letter-meta">
            <span class="letter-number">{{date published_at format="MMMM D, YYYY"}}</span>
            {{#if primary_tag}}<span class="letter-tag">{{primary_tag.name}}</span>{{/if}}
          </div>
          <h4 class="letter-title"><a href="{{url}}">{{title}}</a></h4>
          {{#if custom_excerpt}}
            <p class="letter-excerpt">{{custom_excerpt}}</p>
          {{else}}
            <p class="letter-excerpt">{{excerpt words="24"}}</p>
          {{/if}}
          <a href="{{url}}" class="letter-read">Read this letter &rarr;</a>
        </article>
      {{/foreach}}
    </div>
  </section>
{{/if}}
{{/post}}
